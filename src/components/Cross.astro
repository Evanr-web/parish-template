---
/**
 * Orthodox/Byzantine cross as inline SVG.
 * Renders identically on all platforms — no emoji conversion on mobile.
 *
 * Props:
 *  - size: CSS size string (default "1em")
 *  - color: CSS color (default "currentColor")
 *  - class: additional CSS classes
 */
interface Props {
  size?: string;
  color?: string;
  class?: string;
}

const { size = '1em', color = 'currentColor', class: className = '' } = Astro.props;
---

<svg
  class:list={['cross-svg', className]}
  viewBox="0 0 100 140"
  width={size}
  height={size}
  fill={color}
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- Top bar (shortest) -->
  <rect x="35" y="5" width="30" height="8" rx="1" />
  <!-- Vertical shaft -->
  <rect x="42" y="0" width="16" height="140" rx="1" />
  <!-- Main crossbar -->
  <rect x="15" y="30" width="70" height="10" rx="1" />
  <!-- Bottom slanted bar -->
  <line x1="20" y1="105" x2="80" y2="95" stroke={color} stroke-width="8" stroke-linecap="round" />
</svg>
