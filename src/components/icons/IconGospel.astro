---
interface Props { size?: number; class?: string; }
const { size = 24, class: className = '' } = Astro.props;
---
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
  <!-- Open gospel book with cross on cover -->
  <path d="M4 4h6c1 0 2 1 2 2v14c-1-1-2-1-3-1H4V4z" />
  <path d="M20 4h-6c-1 0-2 1-2 2v14c1-1 2-1 3-1h5V4z" />
  <!-- Small cross on left page -->
  <line x1="7" y1="8" x2="7" y2="12" />
  <line x1="5.5" y1="9.5" x2="8.5" y2="9.5" />
</svg>
